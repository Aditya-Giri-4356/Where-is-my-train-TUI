{
  "name": "where-is-my-train-bridge",
  "version": "1.0.0",
  "description": "Node.js bridge server for RailKit SDK",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:mobile": "MOBILE_MODE=1 node server.js",
    "install:mobile": "npm install --omit=dev && npm uninstall puppeteer && npm install cheerio node-fetch"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-fetch": "^3.3.2",
    "railkit": "^4.0.1"
  },
  "optionalDependencies": {
    "puppeteer": "^22.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
